# Environment variables for the LLM-judge subsystem (Phase 2 §2).
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Load into your shell before running judge commands:
#
#   set -a; source .env; set +a
#
# Or via your shell's preferred .env loader (direnv, dotenv-cli, etc.).

# OpenAI — used by the `openai-mini` (gpt-4o-mini) and `openai` (gpt-4o)
# backends in `trec_biogen.judge`.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Together.ai — `--backend together` (currently mapped to
# Llama-3.3-70B-Instruct-Turbo; Llama-3.1-70B-Turbo moved to dedicated-
# endpoint pricing in 2026-Q2).
TOGETHER_API_KEY=tgp_v1_REPLACE_ME

# HuggingFace Inference Providers — `--backend hf-llama` (Phase 2.5
# second-judge route; same Llama-3.3-70B weights as Together, served via
# HF's router with auto-routing to Groq). Used to derive the two-judge
# intersection-on-contradicts pool at
# data/qrels/biogen2025_taskA_qrels_intersection.jsonl.
HF_TOKEN=hf_REPLACE_ME
