# Data and runs (large, regenerable)
data/
runs/
.hydra/
# Hydra's per-invocation working dirs
outputs/
*.parquet
# local HF model snapshots (re-fetchable via scripts/)
models/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.ruff_cache/
.mypy_cache/

# Venv / build
.venv/
build/
dist/

# MLflow local store
mlruns/

# IDE
.idea/
.vscode/

# Vendor — re-fetch via scripts
external/starter-kit-2025/

# OS
.DS_Store
Thumbs.db

# Secrets — never commit. Use .env.example as the contributor template.
.env
.env.*
!.env.example

# Organisers' qrels and derivative LLM-judge pools — never commit.
# data/ is already excluded above; the patterns below are belt-and-
# suspenders against accidental copies elsewhere in the tree (notebooks,
# scratch dirs, pre-commit moves). Synthetic test fixtures under
# tests/fixtures/mini_qrels*.jsonl do NOT match these patterns and stay
# tracked.
**/biogen20*_taskA_qrels*.jsonl
**/biogen20*_taskA_qrels*.json
**/baseline_labels*.json
**/task_a_judgement_sample*.csv
**/task_a_judgement_sample*.tsv
